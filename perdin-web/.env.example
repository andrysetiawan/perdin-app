# Perdin Web - Environment Variables
# Copy this file to .env and adjust values as needed.

# API Base URL used by the app at runtime (browser-side)
# In development: /api/v1 (Vite proxy forwards to the backend)
# In production: full backend URL, e.g. https://api.perdin.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Backend server URL for Vite dev proxy (only used during development)
VITE_API_PROXY_TARGET=http://localhost:8080
